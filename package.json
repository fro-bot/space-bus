{
  "name": "@fro.bot/space-bus",
  "version": "0.11.0",
  "description": "Space Bus — workspace agent bus for OpenCode. One control agent tasking per-project agents over the OpenCode server API, with an MCP facade for Claude Desktop.",
  "type": "module",
  "license": "MIT",
  "repository": "github:fro-bot/space-bus",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./contract": {
      "types": "./dist/contract.d.ts",
      "import": "./dist/contract.js"
    },
    "./format": {
      "types": "./dist/format.d.ts",
      "import": "./dist/format.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./managed-server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./attach": {
      "types": "./dist/attach.d.ts",
      "import": "./dist/attach.js"
    },
    "./registry": {
      "types": "./dist/registry-entry.d.ts",
      "import": "./dist/registry-entry.js"
    }
  },
  "bin": {
    "space-bus-mcp": "./dist/mcp.js",
    "space-bus": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && bun run build.ts && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "bun build ./src/index.ts ./src/mcp.ts ./src/cli.ts ./src/core.ts ./src/config.ts ./src/contract.ts ./src/format.ts ./src/server.ts --outdir dist --target node --external @opencode-ai/plugin --external @modelcontextprotocol/sdk --external zod --watch & bun build ./src/attach.ts --outdir dist --target node --external @opencode-ai/plugin --external @modelcontextprotocol/sdk --external zod --watch & wait",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "fix": "biome check --write .",
    "test": "bun test",
    "smoke": "bun run scripts/smoke.ts",
    "mcp": "bun run src/mcp.ts",
    "fixture": "bun run scripts/make-fixture.ts",
    "version-changesets": "changeset version && bun install --lockfile-only",
    "publish-changesets": "bun run build && changeset publish",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.17.13 <2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@changesets/cli": "2.31.0",
    "@opencode-ai/plugin": "1.17.15",
    "@types/bun": "1.3.14",
    "typescript": "5.9.3"
  }
}
